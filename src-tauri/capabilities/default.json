{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "updater:default",
    "process:default",
    "core:tray:default",
    "core:window:allow-hide",
    "core:window:allow-show",
    "notification:default",
    "autostart:default",
    "log:default",
    "dialog:default"
  ]
}
